{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "WebSearch",
      "WebFetch",

      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(du:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(pwd:*)",
      "Bash(date:*)",
      "Bash(tree:*)",
      "Bash(jq:*)",
      "Bash(gh:*)",

      "Bash(uv:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(pnpm:*)",
      "Bash(yarn:*)",
      "Bash(npx:*)",
      "Bash(cargo:*)",

      "Bash(ruff:*)",
      "Bash(mypy:*)",
      "Bash(pytest:*)",
      "Bash(python:*)",

      "mcp__context7__*",
      "mcp__fetch__*",
      "mcp__git__*"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su :*)",
      "Bash(/usr/bin/sudo:*)",
      "Bash(doas :*)",
      "Bash(pkexec:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(:|:*)",
      "Bash(mkfs:*)",
      "Bash(dd if:*)",
      "Bash(> /dev:*)",
      "Bash(eval :*)",
      "Bash(crontab:*)",
      "Bash(nohup:*)",
      "Bash(nc :*)",
      "Bash(ncat:*)",
      "Bash(socat:*)",

      "Write(/etc/*)",
      "Write(/usr/*)",
      "Write(/System/*)",
      "Write(/var/*)",
      "Write(/bin/*)",
      "Write(/sbin/*)",
      "Write(~/.ssh/*)",
      "Write(*.pem)",
      "Write(*id_rsa*)",
      "Write(*id_ed25519*)",
      "Write(*.key)",
      "Write(.env.production)",
      "Write(*credentials*)",
      "Write(*secret*)",

      "Edit(~/.ssh/*)",
      "Edit(*.pem)",
      "Edit(*id_rsa*)",
      "Edit(*id_ed25519*)",
      "Edit(.env.production)",
      "Edit(*credentials*)",
      "Edit(*secret*)"
    ]
  }
}
